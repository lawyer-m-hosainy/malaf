# ═══════════════════════════════════════════════════════
# مَلَف (Malaf) — Environment Variables Template
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local for development
# In production (Render), set these in the Dashboard
# ═══════════════════════════════════════════════════════

# ── Supabase (Required) ──
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Sensitive Keys (Backend/Secrets only — NEVER prefix with VITE_) ──
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
ENCRYPTION_KEY=your_32_hex_char_encryption_key # Set in Supabase Secrets
# ENCRYPTION_KEY_PREVIOUS=old_key_for_rotation

# ── AI APIs (Optional — Backend only) ──
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Video (Optional — Backend only) ──
DAILY_API_KEY=

# ── WhatsApp (Optional) ──
WA_VERIFY_TOKEN=your_webhook_verify_token

# ── App Config ──
NODE_ENV=development
PORT=3005
# VITE_ENABLE_DEMO=true  # Only for local demo mode

# ── Production Only ──
# PRODUCTION_URL=https://malaf.pro
# LOG_LEVEL=info

# ── Paymob Payment Gateway (Optional — اشتراكات) ──
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ── Facebook Messenger Bot (Optional) ──
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=malaf_messenger_verify
FB_APP_SECRET=

# ── Sentry Error Monitoring (Required in Production) ──
VITE_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx
SENTRY_ORG=malaf-pro
SENTRY_PROJECT=malaf-frontend
VITE_APP_VERSION=1.0.0

# ── Email Service (Resend — Required for Arabic email templates) ──
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Supabase Auth Webhook Secret ──
SUPABASE_HOOK_SECRET=your_webhook_secret_here

