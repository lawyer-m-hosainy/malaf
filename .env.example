# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Optional fallback AI provider
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
VITE_APP_URL="http://localhost:3005"
VITE_ENABLE_DEMO="true"

# Supabase Configuration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Server-side Encryption Key (Must not be exposed to browser)
ENCRYPTION_KEY="your-server-side-32-byte-secret"

# Daily.co Configuration
DAILY_API_KEY=your_daily_api_key_here
VITE_DAILY_DOMAIN=malaf.daily.co
