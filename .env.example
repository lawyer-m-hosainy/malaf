# ═══════════════════════════════════════════════════════
# مَلَف (Malaf) — Environment Variables Template
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local for development
# In production (Render), set these in the Dashboard
# ═══════════════════════════════════════════════════════

# ── Supabase (Required) ──
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Sensitive Keys (NEVER commit these — use .env.local) ──
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
ENCRYPTION_KEY=your_32_hex_char_encryption_key
# ENCRYPTION_KEY_PREVIOUS=old_key_for_rotation

# ── AI APIs (Optional) ──
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Video (Optional) ──
DAILY_API_KEY=

# ── WhatsApp (Optional) ──
WA_VERIFY_TOKEN=your_webhook_verify_token

# ── App Config ──
NODE_ENV=development
PORT=3005
# VITE_ENABLE_DEMO=true  # Only for local demo mode

# ── Production Only ──
# PRODUCTION_URL=https://malaf-platform.onrender.com
# LOG_LEVEL=info
