rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user belongs to tenant
    function isTenantMember(tenantId) {
      return request.auth != null && request.auth.token.tenantId == tenantId;
    }

    match /clients/{clientId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }
    
    match /cases/{caseId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /invoices/{invoiceId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /audit_logs/{logId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update, delete: if false; // Immutable audit logs
    }
  }
}
