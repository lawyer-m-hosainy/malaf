{
  "name": "malaf-egypt",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --port=3005 --host=0.0.0.0",
    "dev:server": "node server.js",
    "build": "vite build",
    "build:all": "npm run build && echo '✅ Build complete: frontend compiled'",
    "start": "node server.js",
    "prestart": "node -e \"const r=['SUPABASE_URL','SUPABASE_ANON_KEY','SUPABASE_JWT_SECRET'];const m=r.filter(k=>!process.env[k]);if(m.length){console.error('❌ Missing env vars:',m.join(', '));process.exit(1)}console.log('✅ All required env vars present')\"",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "test": "vitest run",
    "test:mutation": "stryker run",
    "test:mutation:ci": "stryker run --reporters clear-text,json",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ai": "vitest run src/services/ai/__tests__/",
    "test:ai:coverage": "vitest run src/services/ai/__tests__/ --coverage",
    "test:ai:mutation": "stryker run",
    "test:health": "curl http://localhost:3005/api/health",
    "test:e2e": "playwright test --config=malaf-e2e/playwright.config.ts",
    "deps:audit": "node scripts/audit-deps.mjs",
    "deps:licenses": "node scripts/check-licenses.mjs",
    "deps:sbom": "node scripts/generate-sbom.mjs",
    "deps:check": "npm run deps:audit && npm run deps:licenses",
    "deps:full": "npm run deps:audit && npm run deps:licenses && npm run deps:sbom",
    "slo:test": "vitest run src/monitoring/__tests__/",
    "deploy:gate": "node scripts/deployment-gate.mjs"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --rule '{\"complexity\": [\"error\", 10], \"max-depth\": [\"error\", 3]}' --max-warnings 0",
      "node -e \"require('child_process').execSync('npx tsc --noEmit', { stdio: 'inherit' })\""
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@daily-co/daily-js": "^0.89.1",
    "@fontsource-variable/cairo": "^5.2.7",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-progress": "^1.1.8",
    "@sentry/react": "^10.53.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.5",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.4.0",
    "eslint-plugin-jsdoc": "^63.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^17.0.5",
    "pwa-asset-generator": "^8.1.4",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.3"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.1.14"
  }
}
